# Exclude local desktop build artifacts and sidecar binaries from deployments
# These files are large and not needed by the Vercel-hosted frontend/API

# Tauri build outputs
src-tauri/target/
src-tauri/bundle/

# Sidecar and bundled node binaries
src-tauri/sidecar/
src-tauri/**/node

# macOS disk images and app bundles
**/*.dmg
**/*.app

# Rust/Cargo build artifacts (safety)
target/

# Common local artifacts
.DS_Store

# =============================================================================
# Railway-only code — exclude from Vercel deploys to reduce Fluid Active CPU
# and deploy footprint. These directories belong to the relay + seed crons
# that run on Railway per docs/architecture, NOT on Vercel edge.
# =============================================================================

# Relay + seed cron scripts. LEADING SLASH anchors to repo root so we
# don't accidentally exclude nested scripts/ directories that the blog-site
# build actually needs (e.g. blog-site/scripts/generate-og-images.mjs).
/scripts/

# Docker/container build artefacts (Railway and local compose, not Vercel)
/docker/
/Dockerfile
/Dockerfile.*
/docker-compose.yml
/docker-compose.override.yml

# Railway builder config (Vercel doesn't read nixpacks)
/nixpacks.toml

# Test suites at repo root (not nested tests/ inside packages which may matter)
/tests/
/e2e/
/proto/
/consumer-prices-core/

# Windsurf / IDE / agent scratch
/.windsurf/
/.agent/
/.agents/
/.claude/
/.factory/
/.planning/
